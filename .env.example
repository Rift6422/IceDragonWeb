# ============================================================
# icedragon-pay 環境變數範本
# 用法:cp .env.example .env.local 並填入實際值
# .env.local 不會被 commit(已在 .gitignore)
# ============================================================

# === Node 環境 ===
NODE_ENV=development
PORT=3000

# === 資料庫(外接 PostgreSQL,由 DBA 提供連線資訊)===
# 範例格式:postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&sslmode=require
# 重要:
#   - PostgreSQL 不在本 repo 的 Docker 內,連線由外部提供
#   - 正式環境建議 sslmode=require
#   - 連線字串視為 secret,不可 commit
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/icedragon_pay?schema=public

# === Redis(reserved,MVP 不使用)===
# MVP 階段 dispatch 同步觸發,重試靠 MyCard §3.6 補儲(最多 5 次)driven。
# 若未來導入 pg-boss 主動重試佇列,queue 走 Postgres,仍不需要 Redis。
# 只在實際接 BullMQ 時才填入。
# REDIS_URL=redis://localhost:6379

# === 玩家前台 ===
PLAYER_FRONTEND_URL=http://localhost:5173

# === JWT(Admin 後台登入用,≥ 32 字元高熵)===
# 產生方式:python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<請產生 ≥ 32 字元隨機字串>
JWT_EXPIRES_IN=8h

# === 後台 IP 白名單(reserved,預設關閉)===
# 啟用後,只有 ADMIN_IP_WHITELIST 內列的 IP 可呼叫 /api/admin/*
# 注意:Cloudflare 後面要透 trust proxy 拿真實 IP
ADMIN_IP_WHITELIST_ENABLED=false
# ADMIN_IP_WHITELIST=1.2.3.4,5.6.7.8

# === Google OAuth ===
GOOGLE_OAUTH_CLIENT_ID=<Google Cloud Console 申請>
GOOGLE_OAUTH_CLIENT_SECRET=<Google Cloud Console 申請>
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# === MyCard 介接 ===
# Hash 用 Key — 機密,絕對不要 commit
MYCARD_HASH_KEY=<32 碼英數混合,大小寫有別,無符號>

# MyCard 發給的識別(等 MyCard 回覆介接資料表後填入)
MYCARD_FAC_SERVICE_ID=
MYCARD_FAC_GAME_ID=
MYCARD_FAC_GAME_NAME=冰龍遊戲

# MyCard API endpoint
MYCARD_API_BASE_TEST=https://testb2b.mycard520.com.tw/MyBillingPay/v1.6
MYCARD_API_BASE_PROD=https://b2b.mycard520.com.tw/MyBillingPay/v1.6
MYCARD_SANDBOX_MODE=true

# 我方回傳網址(填到 AuthGlobal 的 FacReturnURL)
MYCARD_FAC_RETURN_URL=http://localhost:3000/api/mycard/trade-result

# MyCard 入站 callback 的合法來源 IP(用於白名單驗證,逗號分隔)
MYCARD_INBOUND_IP_TEST=218.32.37.148,40.83.124.36
MYCARD_INBOUND_IP_PROD=220.130.127.125,40.81.30.67,40.81.29.75,210.71.189.165,210.71.189.161

# MyCard callback 的合法 User-Agent
MYCARD_USER_AGENT=MyCardGlobalBilling/1.0

# === MyCard 直接儲值(Model B,SHA-1)===
# 由 MyCard 合約時提供。不開 Model B 就留空,backend 啟動時會自動不掛載相關 endpoint。
# MYCARD_DIRECT_KEY1=
# MYCARD_DIRECT_KEY2=

# === 派發到玩家庫存 ===
# 走 PlayFab Server API(由 Unity team 提供 Title ID + Secret Key)
# - PlayFab Title ID:在 PlayFab Game Manager 主頁可看到
# - Secret Key:Settings → Secret Keys,等級**等同 MyCard Hash Key** 機密保護
# - CloudScript 函式名:若 Unity team 用 Pattern 2(我方呼 CloudScript)才需要
#
# 若還沒接 PlayFab,留空 → MailDispatcher 走 MockMailDispatcher
# 不會真打 PlayFab,訂單直接標 DELIVERED(僅 dev 用)。
PLAYFAB_TITLE_ID=
PLAYFAB_SECRET_KEY=
PLAYFAB_CLOUD_SCRIPT_FN=
PLAYFAB_API_TIMEOUT_MS=10000

# === 後台 ===
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=<首次部署用,改完即刪>

# === 觀測 ===
SENTRY_DSN=
LOG_LEVEL=info
